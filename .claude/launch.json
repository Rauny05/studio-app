{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Studio Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Doc Converter",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173"],
      "cwd": "doc-converter/client",
      "port": 5173,
      "autoPort": false
    }
  ,{
      "name": "Speedtest",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "4200", "speedtest"],
      "port": 4200,
      "autoPort": false
    }
  ]
}
